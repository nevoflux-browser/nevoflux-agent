# NevoFlux Eval — environment variable template
# DO NOT commit a real `.env` file. Add real keys via GitHub Actions Secrets
# or your local shell only.

# ---- Agent backend (the LLM the agent uses to perform tasks) ----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=
GEMINI_API_KEY=

# ---- LLM-as-judge backend (used by webjudge.rs for Online-Mind2Web) ----
EVAL_JUDGE_MODEL=o4-mini
EVAL_JUDGE_API_KEY=

# ---- Run config ----
EVAL_DAEMON_ADDR=127.0.0.1:19500
EVAL_TIMEOUT_SECS=300
# CI fails the build if accuracy below this threshold (optional).
# EVAL_MIN_ACCURACY=0.50

# ---- Browser mode config ----
# For --browser-mode=external (dev iteration):
NEVOFLUX_DEV_ENDPOINT=http://localhost:5959

# For --browser-mode=release:
NEVOFLUX_RELEASE_CACHE=.cache/nevoflux-releases
# GH_TOKEN required when downloading releases from a private repo.
GH_TOKEN=

# ---- Benchmark data paths (override defaults) ----
# BROWSECOMP_DATA=eval/benchmarks/browsecomp/data/browsecomp.jsonl
# NEVOFLUX_SUITE_ROOT=eval/nevoflux-suite

